{
  "expo": {
    "name": "Sentinel Command",
    "slug": "sentinel-command",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#06111f"
    },
    "ios": {
      "bundleIdentifier": "org.sentinelprime.command",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "org.sentinelprime.command"
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "9db21156-af7a-4e64-9764-1af5764ed8e3"
      }
    },
    "owner": "lordsleezy"
  }
}
