+RCT_EXPORT_METHOD(probeSshHost:(NSString *)host
+                  port:(NSInteger)port
+                  timeoutMs:(NSInteger)timeoutMs
+                  withCallback:(RCTResponseSenderBlock)callback) {
+    dispatch_async(dispatch_get_global_queue(DISPATCH_QUEUE_PRIORITY_DEFAULT, 0), ^{
+        if (timeoutMs <= 0) {
+            timeoutMs = 8000;
+        }
+
+        CFAbsoluteTime started = CFAbsoluteTimeGetCurrent();
+        struct addrinfo hints;
+        memset(&hints, 0, sizeof(hints));
+        hints.ai_socktype = SOCK_STREAM;
+        hints.ai_family = AF_UNSPEC;
+
+        struct addrinfo *res = NULL;
+        NSString *portString = [NSString stringWithFormat:@"%ld", (long)port];
+        int gai = getaddrinfo([host UTF8String], [portString UTF8String], &hints, &res);
+
+        if (gai != 0) {
+            callback(@[[NSNull null], @{
+                @"target": [NSString stringWithFormat:@"%@:%ld", host, (long)port],
+                @"tcpConnect": @"failure",
+                @"latencyMs": @((NSInteger)((CFAbsoluteTimeGetCurrent() - started) * 1000.0)),
+                @"sshBannerReceived": @NO,
+                @"banner": @"",
+                @"disconnectStage": @"tcp",
+                @"error": [NSString stringWithFormat:@"DNS lookup failed: %s", gai_strerror(gai)],
+            }]);
+            return;
+        }
+
+        int sock = -1;
+        NSString *errorMsg = @"TCP connect failed";
+        BOOL connected = NO;
+
+        for (struct addrinfo *ai = res; ai != NULL; ai = ai->ai_next) {
+            sock = socket(ai->ai_family, ai->ai_socktype, ai->ai_protocol);
+            if (sock < 0) {
+                continue;
+            }
+
+            int flags = fcntl(sock, F_GETFL, 0);
+            fcntl(sock, F_SETFL, flags | O_NONBLOCK);
+
+            int rc = connect(sock, ai->ai_addr, ai->ai_addrlen);
+            if (rc < 0 && errno != EINPROGRESS) {
+                errorMsg = [NSString stringWithFormat:@"connect failed: %s", strerror(errno)];
+                close(sock);
+                sock = -1;
+                continue;
+            }
+
+            fd_set wfds;
+            FD_ZERO(&wfds);
+            FD_SET(sock, &wfds);
+            struct timeval tv;
+            tv.tv_sec = timeoutMs / 1000;
+            tv.tv_usec = (timeoutMs % 1000) * 1000;
+            rc = select(sock + 1, NULL, &wfds, NULL, &tv);
+            if (rc <= 0) {
+                errorMsg = rc == 0 ? @"Connection timed out" : [NSString stringWithFormat:@"select failed: %s", strerror(errno)];
+                close(sock);
+                sock = -1;
+                continue;
+            }
+
+            int so_error = 0;
+            socklen_t len = sizeof(so_error);
+            getsockopt(sock, SOL_SOCKET, SO_ERROR, &so_error, &len);
+            if (so_error != 0) {
+                errorMsg = [NSString stringWithFormat:@"Connection refused/failed: %s", strerror(so_error)];
+                close(sock);
+                sock = -1;
+                continue;
+            }
+
+            fcntl(sock, F_SETFL, flags);
+            connected = YES;
+            break;
+        }
+
+        freeaddrinfo(res);
+
+        NSInteger latencyMs = (NSInteger)((CFAbsoluteTimeGetCurrent() - started) * 1000.0);
+
+        if (!connected || sock < 0) {
+            callback(@[[NSNull null], @{
+                @"target": [NSString stringWithFormat:@"%@:%ld", host, (long)port],
+                @"tcpConnect": @"failure",
+                @"latencyMs": @(latencyMs),
+                @"sshBannerReceived": @NO,
+                @"banner": @"",
+                @"disconnectStage": @"tcp",
+                @"error": errorMsg,
+            }]);
+            return;
+        }
+
+        char buffer[512];
+        memset(buffer, 0, sizeof(buffer));
+
+        fd_set rfds;
+        FD_ZERO(&rfds);
+        FD_SET(sock, &rfds);
+        struct timeval readTv;
+        readTv.tv_sec = timeoutMs / 1000;
+        readTv.tv_usec = (timeoutMs % 1000) * 1000;
+        int readSelect = select(sock + 1, &rfds, NULL, NULL, &readTv);
+        ssize_t bytesRead = 0;
+
+        if (readSelect > 0) {
+            bytesRead = recv(sock, buffer, sizeof(buffer) - 1, 0);
+        }
+
+        close(sock);
+
+        if (readSelect <= 0) {
+            callback(@[[NSNull null], @{
+                @"target": [NSString stringWithFormat:@"%@:%ld", host, (long)port],
+                @"tcpConnect": @"success",
+                @"latencyMs": @(latencyMs),
+                @"sshBannerReceived": @NO,
+                @"banner": @"",
+                @"disconnectStage": @"banner",
+                @"error": readSelect == 0 ? @"Banner read timed out" : [NSString stringWithFormat:@"Banner read failed: %s", strerror(errno)],
+            }]);
+            return;
+        }
+
+        if (bytesRead <= 0) {
+            callback(@[[NSNull null], @{
+                @"target": [NSString stringWithFormat:@"%@:%ld", host, (long)port],
+                @"tcpConnect": @"success",
+                @"latencyMs": @(latencyMs),
+                @"sshBannerReceived": @NO,
+                @"banner": @"",
+                @"disconnectStage": @"banner",
+                @"error": bytesRead == 0 ? @"Remote closed before banner" : [NSString stringWithFormat:@"recv failed: %s", strerror(errno)],
+            }]);
+            return;
+        }
+
+        NSString *banner = [[NSString stringWithUTF8String:buffer] stringByTrimmingCharactersInSet:[NSCharacterSet whitespaceAndNewlineCharacterSet]];
+        BOOL bannerOk = [banner hasPrefix:@"SSH-"];
+
+        callback(@[[NSNull null], @{
+            @"target": [NSString stringWithFormat:@"%@:%ld", host, (long)port],
+            @"tcpConnect": @"success",
+            @"latencyMs": @(latencyMs),
+            @"sshBannerReceived": @(bannerOk),
+            @"banner": bannerOk ? banner : @"",
+            @"disconnectStage": bannerOk ? @"none" : @"banner",
+            @"error": bannerOk ? @"" : @"Received data was not an SSH banner",
+            @"rawData": bannerOk ? @"" : (banner ?: @""),
+        }]);
+    });
+}
