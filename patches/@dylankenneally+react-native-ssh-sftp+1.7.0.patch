+RCT_EXPORT_METHOD(getSessionStatus:(nonnull NSString*)key
+                  withCallback:(RCTResponseSenderBlock)callback) {
+    SSHClient* client = [self clientForKey:key];
+    if (!client || !client._session) {
+        callback(@[[NSNull null], @{
+            @"isConnected": @NO,
+            @"isAuthorized": @NO,
+            @"hasSession": @NO,
+        }]);
+        return;
+    }
+
+    callback(@[[NSNull null], @{
+        @"isConnected": @(client._session.isConnected),
+        @"isAuthorized": @(client._session.isAuthorized),
+        @"hasSession": @YES,
+    }]);
+}
